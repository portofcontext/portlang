# .field structure
# All fields are optional unless marked (required)
#
# Inheritance: a child .field file may set model, tools, boundary, or code_mode
# to "inherit" to pull the value from a parent field one directory up.
# Auto-detection: portlang looks for a parent file one directory up in this order:
#   parent.field  (canonical name, recommended)
#   field.field   (legacy)
#   field.toml    (legacy)
# No explicit flag required — just place parent.field at the eval suite root.
# Example child:  model = "inherit"   tools = "inherit"
# Example parent: a parent.field with [model], [[tool]], [boundary], etc.
#
# Template variables: use {{ var_name }} in any string field (goal, system,
# re_observation, tool descriptions, verifier commands). Declare variables in
# [vars] with required/optional/default, then supply at runtime:
#   portlang run my-task.field --var customer_id=123
#   portlang run my-task.field --vars params.json

name = "..."                    # (required) identifier, used in trajectory storage
description = "..."             # human-readable summary

[vars]                          # optional; declare template variables used in {{ }} syntax
# customer_id = { required = true, description = "Salesforce account ID" }
# region = { required = false, default = "us-east-1", description = "AWS region" }

[model]                         # (required, or model = "inherit" to pull from parent)
name = "..."                    # (required) e.g. "anthropic/claude-sonnet-4.6"
temperature = 0.5               # sampling temperature, default 0.5

[prompt]                        # (required)
goal = "..."                    # (required) initial task, enters context at step 0; supports {{ var }} templates
system = "..."                  # optional system prompt prepended to all interactions; supports {{ var }} templates
re_observation = ["cmd", ...]   # commands that run before each step to refresh context; supports {{ var }} templates

[environment]                   # optional, all fields have defaults
root = "./workspace"            # working directory (maps to /workspace in container)
packages = ["nodejs", "npm"]    # apt packages; uv installed via pip if listed
dockerfile = "./Dockerfile"     # custom Dockerfile (overrides anything in ^); use "inherit" to pull from parent
image = "custom:image"          # pre-built image (overrides anything in ^ on ^^)

[boundary]                      # optional, or boundary = "inherit" to pull from parent
allow_write = ["*.txt", ...]    # glob patterns for writable paths; default: none
collect = ["report.md", ...]    # optional; subset of allow_write to deliver to caller via --output-dir / --json
                                # omit to deliver all allow_write files; set to [] to deliver nothing
network = "deny" | "allow"      # default: allow
max_tokens = 150000             # hard ceiling on total context tokens across entire run
max_cost = "$2.00"              # hard ceiling on total cost
max_steps = 30                  # hard ceiling on agent steps
bash = true | false             # enable built-in bash tool; default: true (set false to restrict to basic filesystem tools only)
output_schema = """{ ... }"""   # optional; JSON schema as a JSON string; multi-line TOML strings recommended
                                # agent must call submit_output with matching JSON; captured in trajectory.structured_output
                                # complements collect: use output_schema for typed structured payloads, collect for files

tools = "inherit"               # optional; inherit [[tool]] list from parent instead of defining inline

[[skill]]                       # repeatable; zero or more; declare skills to load into the agent's context
source = "owner/repo"           # GitHub shorthand (portable with `npx skills add owner/repo`)
# source = "owner/repo/path"    # with subpath into repo
# source = "owner/repo@name"    # select a specific skill within a multi-skill repo
# source = "github:owner/repo"  # explicit github: prefix (equivalent to shorthand)
# source = "https://github.com/owner/repo/tree/main/skills/my-skill"  # full URL with branch/path
# source = "clawhub:name"       # ClawHub registry (clawhub:name or clawhub:org/name)
# source = "https://example.com" # well-known: fetches /.well-known/skills/index.json
# source = "./local-skill.md"   # local .md file relative to .field file
# source = "./skills/my-skill"  # local directory: must contain SKILL.md; scripts/, references/, assets/ copied to workspace
# source = "git@github.com:owner/repo.git"  # SSH git URL

skills = "inherit"              # optional; inherit [[skill]] list from parent instead of defining inline

[[tool]]                        # repeatable; zero or more; type = "python" | "shell" | "mcp"
type = "python"                 # --- python tool ---
file = "./tools/calc.py"        # path to Python file (required)
function = "execute"            # function to call; if omitted, all functions are exposed
name = "..."                    # optional override; auto-extracted from function name
description = "..."             # optional override; auto-extracted from docstring
input_schema = {}               # optional override; auto-extracted from type hints
output_schema = {}              # optional; JSON schema for structured output from this tool

[[tool]]
type = "shell"                  # --- shell tool ---
name = "..."                    # (required)
description = "..."             # (required)
command = "..."                 # shell command template (required)
input_schema = {}               # JSON schema for inputs (required)

[[tool]]
type = "mcp"                    # --- MCP server ---
name = "..."                    # (required) used as MCP namespace
command = "npx" | "uvx" | "..." # executable (required for stdio transport)
args = ["-y", "@stripe/mcp"]   # arguments
env = { KEY = "${KEY}" }        # environment variables; ${VAR} expands from host env
url = "https://..."             # for http/sse transport (replaces command/args)
headers = { Authorization = "Bearer ${TOKEN}" }  # for http/sse transport
transport = "stdio" | "http" | "sse"  # default: stdio

[[verifier]]                    # repeatable; zero or more; type = "shell" | "levenshtein" | "semantic" | "tool_call"
name = "..."                    # (required) identifier
trigger = "on_stop" | "always" | "on_tool:<tool_name>"  # default: on_stop
description = "..."             # injected into context on failure
eval_only = false               # if true, skipped during `portlang run`; only runs during `portlang eval run`

[[verifier]]
type = "shell"                  # --- shell verifier (default when type is omitted) ---
name = "..."                    # (required)
command = "..."                 # (required) shell command; exit 0 = pass, nonzero = fail

[[verifier]]
type = "levenshtein"            # --- normalized edit distance ---
name = "..."                    # (required)
file = "output.txt"             # optional; workspace-relative path; omit to use structured output (output_schema)
expected = "..."                # (required) reference string to compare against
threshold = 0.9                 # normalized similarity [0.0–1.0] required to pass; default: 1.0

[[verifier]]
type = "semantic"               # --- cosine similarity via embeddings ---
name = "..."                    # (required)
file = "output.txt"             # optional; workspace-relative path; omit to use structured output (output_schema)
expected = "..."                # (required) reference string to embed and compare against
threshold = 0.85                # cosine similarity [0.0–1.0] required to pass; default: 0.8
embedding_model = "..."         # local: "bge-small-en-v1.5" (default), "all-minilm-l6-v2", "nomic-embed-text-v1.5"
                                # model downloaded from HuggingFace on first use (~67 MB), no API key required
embedding_url = "https://..."  # optional; set to use an OpenAI-compatible HTTP endpoint instead of local model
                                # reads EMBEDDING_API_KEY or OPENAI_API_KEY from environment when embedding_url is set

[[verifier]]
type = "tool_call"              # --- tool call inspection ---
name = "..."                    # (required)
# With on_tool:<name> trigger — inspect the current tool call's input/output:
field = "/input/path"           # JSON pointer into {input: {...}, output: "..."} e.g. /input/path, /output
matches = "^[a-z]+"            # optional; regex the field value must match
not_matches = "^/etc"          # optional; regex the field value must NOT match
# With on_stop trigger — assert a tool was actually called (catches hallucination):
tool = "bash"                   # (required for on_stop) tool name to require in action history
                                # field/matches/not_matches optionally constrain which call counts
