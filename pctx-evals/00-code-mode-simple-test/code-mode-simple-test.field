name = "code-mode-simple-test"
description = "Simple test to verify Code Mode integration works"

[model]
name = "anthropic/claude-sonnet-4.6"
temperature = 0.0

[prompt]
goal = """
Test that Code Mode is working by executing simple TypeScript code.

Your task:
1. Use the code_mode tool to execute TypeScript code that calculates 42 + 137
2. Write the result to result.txt

The code_mode tool accepts TypeScript code as input.
After executing the code, use the write tool to save the result.

Stop once result.txt contains the answer.
"""

[environment]
root = "./workspace"
code_mode_enabled = true

[boundary]
allow_write = ["result.txt"]
network = "deny"
max_tokens = 50000
max_cost = "$0.10"
max_steps = 5

[[verifier]]
name = "correct-result"
command = """
grep -q "^179$" result.txt
"""
trigger = "on_stop"
description = "Result file contains 179 (42 + 137)"
