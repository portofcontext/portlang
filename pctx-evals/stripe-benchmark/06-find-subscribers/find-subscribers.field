name = "06_find_active_subscription_price"
description = "Returns the subscription ID and price ID for the account's active subscription by extracting the nested price from subscription items"

model = "inherit"
tools = "inherit"

[prompt]
goal = """
You have access to a Stripe MCP server connected to a test account.

Task: Find the active subscription in this account and return the subscription ID and the price ID it is using. The price ID is nested inside the subscription's items. Return the subscription_id and price_id as structured JSON.
"""

[environment]
root = "./workspace"
dockerfile = "inherit"


[boundary]
network = "allow"
max_tokens = 150000
max_cost = "$2.00"
max_steps = 20
output_schema = """
{
  "type": "object",
  "required": ["subscription_id", "price_id"],
  "properties": {
    "subscription_id": { "type": "string", "const": "sub_1T94jeICegwS4jvErlauDPFM" },
    "price_id":        { "type": "string", "const": "price_1T94jLICegwS4jvEJumoLJY3" }
  }
}
"""
