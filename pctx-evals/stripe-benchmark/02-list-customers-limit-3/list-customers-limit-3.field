name = "02_list_customers_limit_3"
description = "Returns exactly 3 customers with their IDs"

model = "inherit"
tools = "inherit"

[prompt]
goal = """
You have access to a Stripe MCP server connected to a test account.

Task: List exactly 3 customers from this Stripe account. Return their customer IDs as structured JSON.
"""

[environment]
root = "./workspace"
dockerfile = "inherit"


[boundary]
network = "allow"
max_tokens = 150000
max_cost = "$2.00"
max_steps = 50
output_schema = """
{
  "type": "object",
  "required": ["customers"],
  "properties": {
    "customers": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^cus_" }
        }
      }
    }
  }
}
"""
