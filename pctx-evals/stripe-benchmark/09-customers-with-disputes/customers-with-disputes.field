name = "09_customers_with_disputes"
description = "Returns the customer IDs and dispute counts for the 2 customers who have had disputes"

model = "inherit"
tools = "inherit"

[prompt]
goal = """
You have access to a Stripe MCP server connected to a test account.

Task: Which customers have had disputes in my Stripe account? For each customer, return their customer ID and the number of disputes they have had as structured JSON.

Hint: disputes contain a charge ID; fetching the charge reveals the customer ID.
"""

[environment]
root = "./workspace"
dockerfile = "inherit"


[boundary]
network = "allow"
max_tokens = 150000
max_cost = "$3.00"
max_steps = 30
output_schema = """
{
  "type": "object",
  "required": ["customers"],
  "properties": {
    "customers": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["customer_id", "dispute_count"],
        "properties": {
          "customer_id":   { "type": "string" },
          "dispute_count": { "type": "integer", "minimum": 1 }
        }
      },
      "contains": {
        "properties": {
          "customer_id":   { "const": "cus_U7JMk0O5Z1x4jK" },
          "dispute_count": { "const": 2 }
        }
      }
    }
  }
}
"""
