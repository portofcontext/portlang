name = "file-processing-code-mode"
description = "Multi-file log processing with Code Mode"

[model]
name = "anthropic/claude-sonnet-4.6"
temperature = 0.0

[prompt]
goal = """
You have log files and processing tools available.

Task:
1. Read all 5 log files (app1.log through app5.log)
2. Extract all lines containing "ERROR" or "WARN"
3. Count occurrences by severity level
4. Write the counts to stats.json

Format: {"ERROR": X, "WARN": Y}

With Code Mode, you can process all files and aggregate without flooding your context.
Stop once stats.json is created.
"""

[environment]
root = "./workspace"

[boundary]
allow_write = ["stats.json"]
network = "deny"
max_tokens = 100000
max_cost = "$1.00"
max_steps = 15

[[tool]]
type = "python"
file = "./tools/log_tools.py"

[[verifier]]
name = "correct-counts"
command = """
python3 -c "
import json
with open('stats.json') as f:
    stats = json.load(f)
assert stats.get('ERROR') == 38, f\"Expected 38 errors, got {stats.get('ERROR')}\"
assert stats.get('WARN') == 26, f\"Expected 26 warnings, got {stats.get('WARN')}\"
print('✓ Log statistics correct')
"
"""
trigger = "on_stop"
description = "Error and warning counts are correct"
